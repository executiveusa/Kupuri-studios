{
  "name": "@kupuri/bff",
  "version": "1.0.0",
  "description": "Kupuri Studios - Backend for Frontend (Hono + TypeScript)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "build": "wrangler deploy --dry-run",
    "start": "wrangler deploy",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src",
    "test": "vitest",
    "test:run": "vitest run",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "@hono/node-server": "^1.0.0",
    "drizzle-orm": "^0.28.0",
    "drizzle-kit": "^0.20.0",
    "pg": "^8.11.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.1.0",
    "zod": "^3.22.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "stripe": "^13.10.0",
    "@stripe/stripe-js": "^2.5.0",
    "ethers": "^6.10.0",
    "@polygon-nft/polygon-sdk": "^1.0.0",
    "langchain": "^0.1.0",
    "langsmith": "^0.1.0",
    "@anthropic-ai/sdk": "^0.7.0",
    "openai": "^4.17.0",
    "@11labs/js": "^0.2.0",
    "posthog-node": "^0.2.0",
    "crypto": "^1.0.3"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "wrangler": "^3.17.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
