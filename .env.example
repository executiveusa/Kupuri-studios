# KUPURI STUDIOS - ENVIRONMENT CONFIGURATION
# Copy this file to .env.local in bff/ and web/ directories

# ===== DATABASE =====
DATABASE_URL="postgresql://kupuri:kupuri@localhost:5432/kupuri"
REDIS_URL="redis://localhost:6379"

# ===== JWT & AUTHENTICATION =====
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRY="7d"
JWT_REFRESH_SECRET="your-super-secret-refresh-key"
JWT_REFRESH_EXPIRY="30d"

# ===== VAULT (API Key Encryption) =====
VAULT_ENCRYPTION_KEY="your-32-char-encryption-key-here-xxxx"
VAULT_CIPHER_ALGORITHM="aes-256-cbc"

# ===== LLM PROVIDERS =====
# Anthropic Claude
ANTHROPIC_API_KEY="sk-ant-your-api-key-here"

# AWS Bedrock
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"

# xAI Grok
GROK_API_KEY="your-grok-api-key"

# Google Gemini
GEMINI_API_KEY="your-gemini-api-key"

# LiteLLM Router
LITELLM_LOG="INFO"
LITELLM_PROXY_PORT="8001"
LITELLM_FALLBACK_ENABLED="true"

# ===== PAYMENT INTEGRATIONS =====
STRIPE_SECRET_KEY="sk_live_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_live_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# ===== PRINT ON DEMAND =====
PRINTFUL_API_KEY="your-printful-api-key"
PRINTFUL_API_BASE="https://api.printful.com"
PRINTFUL_WEBHOOK_SECRET="your-printful-webhook-secret"

PRINTIFY_API_KEY="your-printify-api-key"
PRINTIFY_API_BASE="https://api.printify.com/v1"
PRINTIFY_SHOP_ID="your-printify-shop-id"

# ===== BLOCKCHAIN & NFT =====
POLYGON_RPC_URL="https://polygon-rpc.com"
POLYGON_CHAIN_ID="137"
POLYGON_CONTRACT_ADDRESS="0xYourContractAddressHere"
POLYGON_PRIVATE_KEY="your-private-key-for-contract-deployment"

# Ethers/Web3
INFURA_API_KEY="your-infura-api-key"
ALCHEMY_API_KEY="your-alchemy-api-key"

# Magic Link (Embedded Wallet)
MAGIC_LINK_API_KEY="pk_live_your-magic-link-key"

# ===== VOICE & MUSIC =====
ELEVENLABS_API_KEY="sk_your-elevenlabs-api-key"
ELEVENLABS_ORG_ID="org_your-org-id"

SUNO_API_KEY="your-suno-api-key"
SUNO_WORKSPACE_ID="your-suno-workspace-id"

# ===== SOCIAL MEDIA =====
META_GRAPH_API_TOKEN="your-meta-graph-api-token"
META_GRAPH_API_VERSION="v18.0"
FACEBOOK_PIXEL_ID="your-facebook-pixel-id"

TWITTER_API_KEY="your-twitter-api-key"
TWITTER_API_SECRET="your-twitter-api-secret"
TWITTER_BEARER_TOKEN="your-twitter-bearer-token"

TIKTOK_API_KEY="your-tiktok-api-key"
TIKTOK_API_SECRET="your-tiktok-api-secret"

# ===== GAMBLING & ADULT CONTENT =====
FANVUE_CLIENT_ID="your-fanvue-client-id"
FANVUE_CLIENT_SECRET="your-fanvue-client-secret"
FANVUE_WEBHOOK_SECRET="your-fanvue-webhook-secret"

BETFIN_API_KEY="your-betfin-api-key"
BETFIN_API_SECRET="your-betfin-api-secret"

# ===== ANALYTICS =====
POSTHOG_API_KEY="your-posthog-api-key"
POSTHOG_API_HOST="https://app.posthog.com"

SENTRY_DSN="your-sentry-dsn-url"
SENTRY_ENVIRONMENT="production"

# ===== EMAIL & NOTIFICATIONS =====
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@kupuri.studio"

DISCORD_WEBHOOK_URL="your-discord-webhook-for-alerts"

# ===== EXTERNAL SERVICES =====
LOOX_API_KEY="your-loox-api-key"
LOOX_SHOP_ID="your-loox-shop-id"

# ===== APPLICATION CONFIG =====
NODE_ENV="production"
API_BASE_URL="https://api.kupuri.studio"
WEB_BASE_URL="https://kupuri.studio"
ADULT_BASE_URL="https://adult.kupuri.studio"

# ===== STORAGE =====
AWS_S3_BUCKET="kupuri-studios"
AWS_S3_REGION="us-east-1"
CDN_URL="https://cdn.kupuri.studio"

# ===== CORS =====
CORS_ORIGIN="https://kupuri.studio,https://adult.kupuri.studio,http://localhost:3000"

# ===== RATE LIMITING =====
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ===== LOGGING =====
LOG_LEVEL="info"
LOG_FORMAT="json"

# ===== COMFYUI (Local Image Generation) =====
COMFYUI_API_BASE="http://localhost:8188"
COMFYUI_WORKFLOW_DIR="./workflows/comfyui"

# ===== N8N (Workflow Automation) =====
N8N_HOST="http://localhost:5678"
N8N_API_KEY="your-n8n-api-key"

# ===== FEATURE FLAGS =====
ENABLE_VOICE_CLONING="true"
ENABLE_MUSIC_GENERATION="true"
ENABLE_NFT_MINTING="true"
ENABLE_BETTING="false"
ENABLE_POD_ORDERS="true"
ENABLE_ADULT_VERSION="false"

# ===== DEPLOYMENT =====
VERCEL_URL=""
COOLIFY_API_URL="https://coolify.example.com"
COOLIFY_API_TOKEN="your-coolify-api-token"
